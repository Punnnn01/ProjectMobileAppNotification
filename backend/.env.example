# คัดลอกไฟล์นี้เป็น .env และกรอกข้อมูลจริง
# Copy this file to .env and fill in the real values

# Firebase Service Account (Base64 encoded)
# รับได้จาก: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# จากนั้น encode เป็น base64
FIREBASE_SERVICE_ACCOUNT_BASE64=your_base64_encoded_firebase_credentials_here

# Port ที่ Backend จะรัน
PORT=8080

# Supabase
# รับได้จาก: Supabase Dashboard > Project Settings > API
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
